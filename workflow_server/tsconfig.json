{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "./",
    "paths": {
      "#lib/*": [
        "./src/lib/*"
      ],
      "#modules/*": [
        "./src/modules/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ]
}